{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "rootDir": "src/ts",
    "outDir": "assets/js",
    "strict": true,
    "declaration": true,
    "noEmit": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/ts/**/*.ts"
  ]
}
