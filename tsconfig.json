{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/ts/**/*.ts",
    "assets/js/pages/admin-page.js",
    "assets/js/types/**/*.d.ts"
  ],
  "exclude": [
    "assets/js/core/**/*.js",
    "node_modules"
  ]
}
