{
  "name": "teste",
  "version": "1.0.0",
  "description": "Site institucional estático do CEEJA Paulo Decourt, publicado via GitHub Pages.",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "clean": "node scripts/clean-generated.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "typecheck:watch": "tsc -w -p tsconfig.json",
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -w -p tsconfig.build.json",
    "rebuild": "npm run clean && npm run build",
    "verify": "npm run typecheck && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GustavoRodriguesAlves/Ceeja-Paulo-Decourt.git"
